---
const pathname = Astro.url.pathname;
const subtitle = "The limits of my tokens mean the limits of my world.";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/lab/", label: "Lab" },
  { href: "/about/", label: "About" }
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__mark" href="/">
      <span class="site-header__monogram">WD</span>
      <span class="site-header__identity">
        <span class="site-header__title">Wei Dai</span>
        <span class="site-header__subtitle">{subtitle}</span>
      </span>
    </a>

    <nav aria-label="Primary navigation">
      <ul class="site-nav">
        {
          navItems.map((item) => {
            const isActive =
              item.href === "/"
                ? pathname === item.href
                : pathname.startsWith(item.href);

            return (
              <li>
                <a class:list={["site-nav__link", { "is-active": isActive }]} href={item.href}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>
